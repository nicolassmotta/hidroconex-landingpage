# ignorando arquivos gerados, bibliotecas vendoradas e tooling.

# Catálogo gerado automaticamente por scripts/generateCatalog.js
src/data/catalog.ts linguist-generated

# Componentes de UI vendorados do shadcn/ui (biblioteca, não escritos à mão)
src/components/ui/** linguist-vendored

# Scripts de build e arquivos de configuração de tooling
scripts/**   linguist-vendored
*.config.js  linguist-vendored
*.config.ts  linguist-vendored
