# Copie este arquivo para .env e preencha com os valores reais.
# IMPORTANTE: o .env NUNCA deve ser enviado ao git (já está no .gitignore).
# Em produção (Vercel), configure estas variáveis no painel do projeto,
# NÃO pelo arquivo .env — a Vercel não lê o .env local.

# Chave do Web3Forms usada pelo backend em /api/contact.
WEB3FORMS_ACCESS_KEY="coloque_sua_chave_aqui"

# Senha do painel /admin. Use uma senha longa, aleatória e exclusiva. NÃO compartilhe.
ADMIN_PASSWORD="troque-esta-senha"

# Porta do servidor Node local (não usada na Vercel).
PORT=3333

# Conexão com o MongoDB. Local: mongodb://127.0.0.1:27017
# Produção (Atlas): mongodb+srv://usuario:senha@cluster.xxxxx.mongodb.net
MONGODB_URI="mongodb://127.0.0.1:27017"

# Nome do banco de dados.
MONGODB_DB_NAME="hidroconex"

# Tamanho máximo (MB) das fotos enviadas pelo admin. Recomendado 3 na Vercel.
IMAGE_LIMIT_MB=3

# (Opcional, recomendado em produção) Trava a API para aceitar apenas o seu domínio.
# Ex.: https://www.hidroconex.com.br
# CORS_ORIGIN=""

# (Opcional) Duração da sessão do admin em horas. Padrão: 8.
# ADMIN_TOKEN_TTL_HOURS=8

# (Opcional) Proteção contra força-bruta no login do admin.
# Após LOGIN_MAX_ATTEMPTS tentativas erradas em LOGIN_WINDOW_MIN minutos,
# o IP é bloqueado por LOGIN_BLOCK_MIN minutos. Padrões: 8 / 15 / 15.
# LOGIN_MAX_ATTEMPTS=8
# LOGIN_WINDOW_MIN=15
# LOGIN_BLOCK_MIN=15

# (Opcional) Proteção contra spam no formulário de contato.
# Após CONTACT_MAX_ATTEMPTS envios em CONTACT_WINDOW_MIN minutos,
# o IP é bloqueado por CONTACT_BLOCK_MIN minutos. Padrões: 5 / 10 / 20.
# CONTACT_MAX_ATTEMPTS=5
# CONTACT_WINDOW_MIN=10
# CONTACT_BLOCK_MIN=20

# (Opcional) Retenção dos eventos de falha exibidos no admin. Padrão: 14 dias; máximo: 90.
# FAILURE_EVENT_TTL_DAYS=14
